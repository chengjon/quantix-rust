// quantix-rust 回测工作区布局
// 启动命令: zellij --layout-path config/zellij/layouts/backtest.kdl

layout {
    // 标签栏
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }

    // 主内容区域 - 2 窗格布局
    pane split_direction="horizontal" {
        // 左侧: 回测控制台 (70%)
        pane size="70%" {
            command "quantix"
            args "strategy" "run" "--interactive"
        }

        // 右侧: 回测结果和日志 (30%)
        pane split_direction="vertical" {
            // 上: 实时结果
            pane size="50%" {
                command "watch"
                args "-n" "5" "quantix" "backtest" "results" "--latest"
            }

            // 下: 详细日志
            pane size="50%" {
                command "quantix"
                args "logs" "--level" "debug" "--follow"
            }
        }
    }

    // 状态栏
    pane size=2 borderless=true {
        plugin location="zellij:status-bar"
    }
}
