# Quantix CLI 环境配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置 (与 Python quantix 项目共享)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quantix
POSTGRES_USER=quantix
POSTGRES_PASSWORD=your_password

TDENGINE_HOST=localhost
TDENGINE_PORT=6041
TDENGINE_DB=quantix
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata

# 数据源配置
TDX_HOSTS=114.80.63.12,114.80.63.13
TDX_PORT=7709
TDX_TIMEOUT=5000

AKSHARE_BASE_URL=http://localhost:8000
AKSHARE_RATE_LIMIT=100

# 日志配置
RUST_LOG=quantix_cli=info,sqlx=warn

# 配置目录 (指向原 quantix 项目)
QUANTIX_CONFIG_DIR=../config

# ============================================================
# 通知配置 (Phase 1: 多渠道通知扩展)
# ============================================================

# 通知最低级别 (info | warning | error | critical)
NOTIFICATION_MIN_LEVEL=warning

# 通知日志路径
NOTIFICATION_LOG_PATH=./logs/notifications.log

# 通用 Webhook
WEBHOOK_URL=

# 企业微信 (WeChat Work)
WECHAT_WORK_WEBHOOK_URL=

# 飞书 (Feishu/Lark)
FEISHU_WEBHOOK_URL=

# Telegram (预留)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord (预留)
DISCORD_WEBHOOK_URL=

# Slack (预留)
SLACK_WEBHOOK_URL=

# 钉钉 (预留)
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# PushPlus (预留)
PUSHPLUS_TOKEN=

# ============================================================
# AI 决策配置 (Phase 2: LLM 集成)
# ============================================================

# 默认 LLM 提供商 (deepseek | openai | ollama | anthropic | gemini)
LLM_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini API
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Ollama (本地部署)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# 新闻搜索配置 (Phase 3)
# ============================================================

# Tavily (推荐，高质量 AI 友好)
TAVILY_API_KEY=

# SerpAPI (Google 搜索结果)
SERPAPI_API_KEY=

# 博查 (中文优化)
BOCHA_API_KEY=
