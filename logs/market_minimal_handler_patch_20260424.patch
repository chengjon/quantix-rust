+
+fn print_strong_sector_stock_rows(
+    rows: &[StrongSectorStockRow],
+    metric_label: &str,
+    use_market_cap: bool,
+) {
+    if rows.is_empty() {
+        println!("📭 没有可展示的个股数据");
+        return;
+    }
+
+    println!(
+        "{:<4} {:<10} {:<12} {:<12} {:<12} {}",
+        "排名", "行业", "代码", "名称", "现价", metric_label
+    );
+    println!("{}", "-".repeat(84));
+
+    for (idx, row) in rows.iter().enumerate() {
+        let metric = if use_market_cap {
+            row.market_cap
+        } else {
+            row.latest_report_profit
+        };
+        println!(
+            "{:<4} {:<10} {:<12} {:<12} {:<12.2} {}",
+            idx + 1,
+            row.sector_name,
+            row.code,
+            row.name,
+            row.latest_price,
+            format_market_decimal(metric)
+        );
+    }
+}
+
+fn format_market_decimal(value: Option<Decimal>) -> String {
+    match value {
+        Some(value) => format!("{:.2}", value),
+        None => "-".to_string(),
+    }
+}
