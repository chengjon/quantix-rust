# 开发环境 Dockerfile
# 支持热重载和实时开发

FROM rust:1.75-slim

# 安装开发依赖
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    postgresql-client \
    clickhouse-client \
    git \
    vim \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 安装 cargo-watch（热重载工具）
RUN cargo install cargo-watch

# 安装 cargo-edit（依赖管理工具）
RUN cargo install cargo-edit

WORKDIR /app

# 复制 Cargo 配置
COPY Cargo.toml Cargo.lock ./

# 复制源代码
COPY src ./src
COPY config ./config

# 暴露端口
EXPOSE 8080

# 设置开发环境变量
ENV RUST_LOG=debug \
    RUST_BACKTRACE=1

# 使用 cargo-watch 进行开发
# 保存源代码时自动重新编译
CMD ["cargo-watch", "-x", "run"]
